{
  "name": "isee-v2",
  "version": "2.0.0",
  "description": "ISEE v2 - Idea Synthesis and Extraction Engine",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch run src/server.ts",
    "start": "bun run src/server.ts",
    "pipeline": "bun run src/pipeline.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test:golden": "bun test test/golden.test.ts --timeout 360000"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "marked": "^15.0.0",
    "openai": "^4.70.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.2"
  },
  "author": "Joseph Fajen",
  "license": "MIT"
}
